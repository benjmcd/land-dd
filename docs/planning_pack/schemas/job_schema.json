{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/job.schema.json",
  "title": "Job",
  "type": "object",
  "required": [
    "job_id",
    "job_type",
    "status",
    "payload"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "format": "uuid"
    },
    "workspace_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "job_type": {
      "type": "string"
    },
    "status": {
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "cancelled",
        "needs_review"
      ]
    },
    "priority": {
      "type": "integer"
    },
    "payload": {
      "type": "object"
    },
    "idempotency_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "attempts": {
      "type": "integer"
    },
    "max_attempts": {
      "type": "integer"
    },
    "last_error": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}