APP_NAME=land-diligence
APP_ENV=local
DATABASE_URL=postgresql+psycopg://land:land@localhost:5432/land_diligence
# Local/dev/test may use false for fixture demos. Non-local APP_ENV values must use true.
USE_DB_SERVICES=false
OBJECT_STORE_ROOT=./local_artifacts/object_store
ENABLE_LIVE_CONNECTORS=false
LOG_LEVEL=INFO
REQUIRE_API_KEY=false
# API_KEYS is local/dev/development/test only. Non-local REQUIRE_API_KEY=true
# requires API_KEY_SPECS entries with sha256:<64-hex> secrets.
API_KEYS=
# API_KEY_SPECS supports id|active|secret locally; non-local secrets must be
# id|active|sha256:<64-hex> or id|retired|sha256:<64-hex>.
API_KEY_SPECS=
# Set a high-entropy value in shared or non-local API-key-locked environments to keep
# /ui auth cookies valid across app restarts and replicas.
# Blank is local/dev/development/test only and uses a per-process local secret.
UI_AUTH_COOKIE_SECRET=
# Non-local APP_ENV values enable this automatically; set explicitly when needed.
UI_AUTH_COOKIE_SECURE=false
REPORT_AUTH_MODE=trusted_headers
# Required only when REPORT_AUTH_MODE=signed_token. Store hosted values in the
# secret manager; do not commit real token-signing secrets.
REPORT_IDENTITY_TOKEN_SECRET=
ENABLE_RATE_LIMIT=false
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
ENABLE_METRICS=true
# REVIEWER_ACCOUNTS supports id:raw-token for local fixtures. Non-local APP_ENV
# values require explicit accounts using id:sha256:<64-hex> token specs.
REVIEWER_ACCOUNTS=fixture-reviewer:fixture-token-123
# REVIEWER_ACCOUNT_SCOPES must explicitly name every reviewer account in non-local APP_ENV.
REVIEWER_ACCOUNT_SCOPES=fixture-reviewer:connector:run|connector:review|operations:read|report:approve|report:retry|report:run

# Docker Compose backend service defaults.
BACKEND_PORT=8000
DB_PORT=5432
COMPOSE_DATABASE_URL=postgresql+psycopg://land:land@db:5432/land_diligence
COMPOSE_USE_DB_SERVICES=true
COMPOSE_OBJECT_STORE_ROOT=/app/local_artifacts/object_store

# Optional Compose worker profile for queued DS-002 live connector jobs.
LIVE_CONNECTOR_WORKER_ID=compose-live-connector-worker
LIVE_CONNECTOR_WORKER_MAX_JOBS=1
LIVE_CONNECTOR_WORKER_POLL_SECONDS=30
LIVE_CONNECTOR_WORKER_IDLE_POLLS=0

# DB connection pool settings
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800

# Optional local backup/restore validation.
DATABASE_URL_SYNC=postgresql://land:land@localhost:5432/land_diligence
DATABASE_ADMIN_URL_SYNC=postgresql://land:land@localhost:5432/postgres
RESTORE_CHECK_DB_NAME=land_diligence_restore_check
RESTORE_CHECK_KEEP_DB=0
