APP_NAME=land-diligence
APP_ENV=local
APP_STORAGE_BACKEND=postgres
DATABASE_URL=postgresql+psycopg://land:land@localhost:5432/land_diligence
DATABASE_URL_SYNC=postgresql://land:land@localhost:5432/land_diligence
OBJECT_STORE_ROOT=./local_artifacts/object_store
ENABLE_LIVE_CONNECTORS=false
REPORT_AUTH_MODE=trusted_headers
# Required when REPORT_AUTH_MODE=signed_token; use at least 32 characters.
REPORT_IDENTITY_TOKEN_SECRET=
