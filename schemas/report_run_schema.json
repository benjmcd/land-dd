{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/report-run.schema.json",
  "title": "ReportRunContract",
  "type": "object",
  "required": [
    "report_run_id",
    "workspace_id",
    "requested_by",
    "area_id",
    "intent_code",
    "idempotency_key",
    "status",
    "review_status",
    "reviewed_by",
    "reviewed_at",
    "review_actions",
    "source_manifest",
    "assumptions",
    "caveats",
    "evidence",
    "claims",
    "unknowns",
    "red_flags",
    "advisory_claims",
    "verification_tasks",
    "artifact_metadata",
    "started_at",
    "finished_at",
    "output_uri"
  ],
  "properties": {
    "report_run_id": {
      "type": "string",
      "format": "uuid"
    },
    "workspace_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "requested_by": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "area_id": {
      "type": "string",
      "format": "uuid"
    },
    "intent_code": {
      "type": "string",
      "enum": [
        "rural_land_purchase",
        "homestead_feasibility",
        "farmland",
        "development",
        "solar",
        "data_center",
        "conservation",
        "mineral_resource_screen",
        "speculative_hold"
      ]
    },
    "idempotency_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "cancelled",
        "needs_review"
      ]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "draft",
        "needs_review",
        "approved",
        "rejected",
        "superseded"
      ]
    },
    "reviewed_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "reviewed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "review_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "action",
          "from_status",
          "to_status",
          "reviewer_id",
          "reason",
          "reviewed_at"
        ],
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "draft",
              "needs_review",
              "approved",
              "rejected",
              "superseded"
            ]
          },
          "from_status": {
            "type": "string",
            "enum": [
              "draft",
              "needs_review",
              "approved",
              "rejected",
              "superseded"
            ]
          },
          "to_status": {
            "type": "string",
            "enum": [
              "draft",
              "needs_review",
              "approved",
              "rejected",
              "superseded"
            ]
          },
          "reviewer_id": {
            "type": "string"
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          },
          "reviewed_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    },
    "source_manifest": {
      "type": "object",
      "required": [
        "source_ids",
        "source_count",
        "evidence_count",
        "claim_count",
        "ruleset_id",
        "ruleset_version",
        "source_names",
        "source_details"
      ],
      "properties": {
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        },
        "source_count": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_count": {
          "type": "integer",
          "minimum": 0
        },
        "claim_count": {
          "type": "integer",
          "minimum": 0
        },
        "ruleset_id": {
          "type": "string",
          "minLength": 1
        },
        "ruleset_version": {
          "type": "string",
          "minLength": 1
        },
        "source_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_details": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "source_id",
              "name",
              "authority_level",
              "license_status",
              "commercial_use_status",
              "freshness_class",
              "review_status",
              "review_owner",
              "last_checked_at"
            ],
            "properties": {
              "source_id": {
                "type": "string",
                "format": "uuid"
              },
              "name": {
                "type": "string"
              },
              "authority_level": {
                "type": "string",
                "enum": [
                  "official_primary",
                  "official_secondary",
                  "commercial_normalized",
                  "open_community",
                  "derived_model",
                  "user_supplied",
                  "unknown"
                ]
              },
              "license_status": {
                "type": "string"
              },
              "commercial_use_status": {
                "type": "string"
              },
              "freshness_class": {
                "type": "string"
              },
              "review_status": {
                "type": "string"
              },
              "review_owner": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "last_checked_at": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "https://example.com/schemas/evidence.schema.json"
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "https://example.com/schemas/claim.schema.json"
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "$ref": "https://example.com/schemas/claim.schema.json"
      }
    },
    "red_flags": {
      "type": "array",
      "items": {
        "$ref": "https://example.com/schemas/claim.schema.json"
      }
    },
    "advisory_claims": {
      "type": "array",
      "items": {
        "$ref": "https://example.com/schemas/claim.schema.json"
      }
    },
    "verification_tasks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifact_metadata": {
      "type": "object",
      "required": [
        "artifact_kind",
        "report_schema",
        "cost_metrics"
      ],
      "properties": {
        "artifact_kind": {
          "type": "string",
          "const": "report_run"
        },
        "report_schema": {
          "type": "string",
          "const": "report_run_contract_v1"
        },
        "persistence": {
          "type": "string",
          "enum": [
            "memory",
            "postgres+object_store"
          ]
        },
        "output_uri": {
          "type": "string"
        },
        "machine_json_uri": {
          "type": "string"
        },
        "validation": {
          "type": "object",
          "required": [
            "contract_name",
            "contract_version",
            "validation_profile",
            "ruleset_id",
            "ruleset_version"
          ],
          "properties": {
            "contract_name": {
              "type": "string",
              "const": "ReportRunContract"
            },
            "contract_version": {
              "type": "string",
              "const": "report_run_contract_v1"
            },
            "validation_profile": {
              "type": "string",
              "const": "fixture_report_contract_v1"
            },
            "ruleset_id": {
              "type": "string",
              "minLength": 1
            },
            "ruleset_version": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        },
        "cost_metrics": {
          "type": "object",
          "required": [
            "evidence_count",
            "claim_count",
            "unknown_count",
            "advisory_count",
            "red_flag_count",
            "verification_task_count",
            "estimated_total_usd_cents",
            "compute_usd_cents",
            "storage_usd_cents",
            "llm_usd_cents",
            "map_tile_usd_cents",
            "geocoding_usd_cents",
            "paid_data_usd_cents",
            "human_review_usd_cents",
            "human_review_minutes"
          ],
          "properties": {
            "evidence_count": {
              "type": "integer",
              "minimum": 0
            },
            "claim_count": {
              "type": "integer",
              "minimum": 0
            },
            "unknown_count": {
              "type": "integer",
              "minimum": 0
            },
            "advisory_count": {
              "type": "integer",
              "minimum": 0
            },
            "red_flag_count": {
              "type": "integer",
              "minimum": 0
            },
            "verification_task_count": {
              "type": "integer",
              "minimum": 0
            },
            "estimated_total_usd_cents": {
              "type": "integer",
              "minimum": 0
            },
            "compute_usd_cents": {
              "type": "integer",
              "minimum": 0
            },
            "storage_usd_cents": {
              "type": "integer",
              "minimum": 0
            },
            "llm_usd_cents": {
              "type": "integer",
              "minimum": 0
            },
            "map_tile_usd_cents": {
              "type": "integer",
              "minimum": 0
            },
            "geocoding_usd_cents": {
              "type": "integer",
              "minimum": 0
            },
            "paid_data_usd_cents": {
              "type": "integer",
              "minimum": 0
            },
            "human_review_usd_cents": {
              "type": "integer",
              "minimum": 0
            },
            "human_review_minutes": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "output_uri": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri-reference"
    }
  },
  "additionalProperties": false
}
