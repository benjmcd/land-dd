{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/qualification-criterion-catalog-v3.json",
  "title": "Qualification Criterion Catalog V3",
  "type": "object",
  "required": [
    "schema_version",
    "generated_from",
    "framework_sha256",
    "criterion_count",
    "notes",
    "criteria"
  ],
  "properties": {
    "schema_version": {
      "const": "qualification_criterion_catalog_v3"
    },
    "generated_from": {
      "type": "string",
      "minLength": 1
    },
    "framework_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "criterion_count": {
      "type": "integer",
      "minimum": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "criteria": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": false
}