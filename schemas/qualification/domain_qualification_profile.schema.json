{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/domain-qualification-profile-v3.json",
  "title": "Domain Qualification Profile V3",
  "type": "object",
  "required": [
    "schema_version",
    "domain_id",
    "version",
    "status",
    "scope",
    "reference_hierarchy",
    "issue_taxonomy",
    "severity_rubric",
    "confidence_rubric",
    "source_requirements",
    "unknown_states",
    "metrics",
    "known_exclusions",
    "owner",
    "reviewers",
    "expires_at",
    "frozen_at",
    "approved_by",
    "invalidation_triggers",
    "field_surveillance_plan"
  ],
  "properties": {
    "schema_version": {
      "const": "domain_qualification_profile_v3"
    },
    "domain_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "DRAFT",
        "FROZEN",
        "SUPERSEDED"
      ]
    },
    "scope": {
      "type": "object",
      "required": [
        "intents",
        "geographies",
        "input_modalities",
        "output_channels"
      ],
      "properties": {
        "intents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "geographies": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "input_modalities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "output_channels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "reference_hierarchy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "issue_taxonomy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "severity_rubric": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "confidence_rubric": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "source_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "spatial_temporal_tolerances": {
      "type": "object"
    },
    "unknown_states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "known_exclusions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "reviewers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "frozen_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "approved_by": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "invalidation_triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "field_surveillance_plan": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "FROZEN"
          }
        }
      },
      "then": {
        "properties": {
          "frozen_at": {
            "type": "string",
            "format": "date-time"
          },
          "approved_by": {
            "minItems": 1
          },
          "field_surveillance_plan": {
            "type": "string",
            "minLength": 1
          },
          "reviewers": {
            "minItems": 1
          }
        }
      }
    }
  ]
}