{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/source.schema.json",
  "title": "SourceContract",
  "type": "object",
  "required": [
    "source_id",
    "name",
    "organization",
    "homepage_url",
    "source_type",
    "authority_level",
    "domain",
    "geographic_scope",
    "update_cadence",
    "license_status",
    "commercial_use_status",
    "redistribution_status",
    "license_summary",
    "attribution_required",
    "cache_allowed",
    "export_allowed",
    "ai_use_allowed",
    "raw_data_allowed",
    "freshness_class",
    "last_checked_at",
    "review_owner",
    "review_status",
    "notes",
    "metadata"
  ],
  "properties": {
    "source_id": {
      "type": "string",
      "format": "uuid"
    },
    "name": {
      "type": "string"
    },
    "organization": {
      "type": [
        "string",
        "null"
      ]
    },
    "homepage_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "source_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "domain": {
      "type": "string"
    },
    "authority_level": {
      "type": "string",
      "enum": [
        "official_primary",
        "official_secondary",
        "commercial_normalized",
        "open_community",
        "derived_model",
        "user_supplied",
        "unknown"
      ]
    },
    "geographic_scope": {
      "type": [
        "string",
        "null"
      ]
    },
    "update_cadence": {
      "type": [
        "string",
        "null"
      ]
    },
    "commercial_use_status": {
      "type": "string"
    },
    "license_status": {
      "type": "string"
    },
    "redistribution_status": {
      "type": "string"
    },
    "license_summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "attribution_required": {
      "type": "boolean"
    },
    "ai_use_allowed": {
      "type": "string"
    },
    "cache_allowed": {
      "type": "string"
    },
    "export_allowed": {
      "type": "string"
    },
    "raw_data_allowed": {
      "type": "string"
    },
    "freshness_class": {
      "type": "string"
    },
    "last_checked_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "review_owner": {
      "type": [
        "string",
        "null"
      ]
    },
    "review_status": {
      "type": "string"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
